{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "von",
    "scopeName": "source.von",
    "fileTypes": ["von"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#objects"
        },
        {
            "include": "#arrays"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#literals"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.von",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.von",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "objects": {
            "patterns": [
                {
                    "name": "meta.object.von",
                    "begin": "\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.object.begin.von"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.object.end.von"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#comments"
                        },
                        {
                            "include": "#object-key"
                        },
                        {
                            "include": "#objects"
                        },
                        {
                            "include": "#arrays"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#numbers"
                        },
                        {
                            "include": "#literals"
                        },
                        {
                            "name": "punctuation.separator.pair.von",
                            "match": ":"
                        },
                        {
                            "name": "punctuation.separator.object.von",
                            "match": ","
                        }
                    ]
                }
            ]
        },
        "object-key": {
            "patterns": [
                {
                    "name": "meta.object.key.von",
                    "match": "^\\s*([\\p{L}_$][\\p{L}\\p{N}_$]*)\\s*(:)",
                    "captures": {
                        "1": {
                            "name": "entity.name.tag.key.unquoted.von"
                        },
                        "2": {
                            "name": "punctuation.separator.pair.von"
                        }
                    }
                },
                {
                    "name": "meta.object.key.von",
                    "match": "^\\s*(\"[^\"]*\")\\s*(:)",
                    "captures": {
                        "1": {
                            "name": "string.quoted.double.von",
                            "patterns": [
                                {
                                    "name": "constant.character.escape.von",
                                    "match": "\\\\."
                                }
                            ]
                        },
                        "2": {
                            "name": "punctuation.separator.pair.von"
                        }
                    }
                },
                {
                    "name": "meta.object.key.von",
                    "match": "^\\s*('[^']*')\\s*(:)",
                    "captures": {
                        "1": {
                            "name": "string.quoted.single.von",
                            "patterns": [
                                {
                                    "name": "constant.character.escape.von",
                                    "match": "\\\\."
                                }
                            ]
                        },
                        "2": {
                            "name": "punctuation.separator.pair.von"
                        }
                    }
                }
            ]
        },
        "arrays": {
            "patterns": [
                {
                    "name": "meta.array.von",
                    "begin": "\\[",
                    "end": "\\]",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.array.begin.von"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.array.end.von"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#comments"
                        },
                        {
                            "include": "#objects"
                        },
                        {
                            "include": "#arrays"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#numbers"
                        },
                        {
                            "include": "#literals"
                        },
                        {
                            "name": "punctuation.separator.array.von",
                            "match": ","
                        }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.von",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.von",
                            "match": "\\\\[\"\\\\/bfnrt]"
                        },
                        {
                            "name": "constant.character.escape.unicode.von",
                            "match": "\\\\u[0-9a-fA-F]{4}"
                        },
                        {
                            "name": "constant.character.escape.line-continuation.von",
                            "match": "\\\\\\s*\\n"
                        },
                        {
                            "name": "invalid.illegal.escape.von",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.von",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.von",
                            "match": "\\\\[\"'\\\\/bfnrt]"
                        },
                        {
                            "name": "constant.character.escape.unicode.von",
                            "match": "\\\\u[0-9a-fA-F]{4}"
                        },
                        {
                            "name": "constant.character.escape.line-continuation.von",
                            "match": "\\\\\\s*\\n"
                        },
                        {
                            "name": "invalid.illegal.escape.von",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.von",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.infinity.von",
                    "match": "\\bInfinity\\b"
                },
                {
                    "name": "constant.numeric.nan.von",
                    "match": "\\bNaN\\b"
                },
                {
                    "name": "constant.numeric.float.von",
                    "match": "[+-]?(?:\\d+\\.\\d*|\\d*\\.\\d+)(?:[eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.von",
                    "match": "[+-]?\\d+(?:[eE][+-]?\\d+)?\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.language.null.von",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "constant.language.boolean.true.von",
                    "match": "\\btrue\\b"
                },
                {
                    "name": "constant.language.boolean.false.von",
                    "match": "\\bfalse\\b"
                },
                {
                    "name": "constant.language.undefined.von",
                    "match": "\\bundefined\\b"
                }
            ]
        }
    }
}
