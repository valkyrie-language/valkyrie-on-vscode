{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "valkyrie",
    "scopeName": "source.valkyrie",
    "fileTypes": [
        "v",
        "vk",
        "vx",
        "valkyrie"
    ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#annotations"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#types"
        },
        {
            "include": "#generics"
        },
        {
            "include": "#function-definitions"
        },
        {
            "include": "#function-calls"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.documentation.valkyrie",
                    "match": "⍝.*$"
                },
                {
                    "name": "comment.line.documentation.valkyrie",
                    "match": "#\\?.*$"
                },
                {
                    "name": "comment.line.number-sign.valkyrie",
                    "match": "#(?!\\?|<).*$"
                },
                {
                    "name": "comment.block.valkyrie",
                    "begin": "<#",
                    "end": "#>"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.valkyrie",
                    "match": "\\b(namespace|using|as|from|if|else|for|in|while|until|loop|break|continue|case|match|return|end|type|mut|method|true|false|try|catch|raise|resume|package)\\b"
                },
                {
                    "name": "keyword.declaration.valkyrie",
                    "match": "\\b(class|union|unity|unite|structure|micro|mezzo|macro|let|flags|self|Self|trait|impl|imply|initiate|constructor|pub|priv|async|await|yield|spawn|get|set)\\b"
                },
                {
                    "name": "keyword.other.valkyrie",
                    "match": "\\b(where|with|extends|implements|abstract|final|sealed|override|virtual|static|const|readonly)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.format.valkyrie",
                    "begin": "(\\bf)(\")",
                    "end": "\"",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.valkyrie"
                        },
                        "2": {
                            "name": "punctuation.definition.string.begin.valkyrie"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.embedded.line.valkyrie",
                            "begin": "<\\$",
                            "end": "\\$>",
                            "patterns": [
                                {
                                    "include": "#expressions"
                                }
                            ]
                        },
                        {
                            "name": "meta.embedded.line.valkyrie",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                {
                                    "include": "#expressions"
                                }
                            ]
                        },
                        {
                            "name": "constant.character.escape.valkyrie",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.raw.valkyrie",
                    "begin": "(\\b[rst])(\")",
                    "end": "\"",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.valkyrie"
                        },
                        "2": {
                            "name": "punctuation.definition.string.begin.valkyrie"
                        }
                    }
                },
                {
                    "name": "string.regexp.valkyrie",
                    "begin": "(\\bre)(\")",
                    "end": "\"",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.valkyrie"
                        },
                        "2": {
                            "name": "punctuation.definition.string.begin.valkyrie"
                        }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.valkyrie",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.interpolated.valkyrie",
                    "begin": "\"",
                    "end": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.valkyrie"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.embedded.line.valkyrie",
                            "begin": "<\\$",
                            "end": "\\$>",
                            "patterns": [
                                {
                                    "include": "#expressions"
                                }
                            ]
                        },
                        {
                            "name": "meta.embedded.line.valkyrie",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                {
                                    "include": "#expressions"
                                }
                            ]
                        },
                        {
                            "name": "constant.character.escape.valkyrie",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.valkyrie",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.valkyrie",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.backtick.valkyrie",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "constant.character.escape.valkyrie",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.decimal.valkyrie",
                    "match": "-?\\b\\d+\\.\\d+([eE][+-]?\\d+)?([\\p{L}_][\\p{L}\\p{N}_]*)?\\b"
                },
                {
                    "name": "constant.numeric.integer.valkyrie",
                    "match": "-?\\b\\d+([\\p{L}_][\\p{L}\\p{N}_]*)?\\b"
                },
                {
                    "name": "constant.numeric.hex.valkyrie",
                    "match": "\\b0x[0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.valkyrie",
                    "match": "\\b0b[01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.valkyrie",
                    "match": "\\b0o[0-7_]+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.valkyrie",
                    "match": "\\b(bool|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|char|str|String|Vec|Map|Set|Option|Result|Box|Rc|Arc|usize|isize)\\b"
                },
                {
                    "name": "entity.name.type.valkyrie",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "storage.modifier.valkyrie",
                    "match": "\\?"
                }
            ]
        },
        "generics": {
            "patterns": [
                {
                    "name": "meta.generic.parameters.valkyrie",
                    "begin": "(?<=\\b[A-Z][a-zA-Z0-9_]*)(⟨|<(?![=<>]))",
                    "end": "(⟩|(?<!-)>)(?!\\s*[=<>])",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.generic.begin.valkyrie"
                        }
                    },
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.generic.end.valkyrie"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#types"
                        },
                        {
                            "name": "punctuation.separator.valkyrie",
                            "match": ","
                        },
                        {
                            "name": "keyword.other.valkyrie",
                            "match": "\\b(where|with)\\b"
                        },
                        {
                            "include": "#generics"
                        }
                    ]
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "meta.annotation.valkyrie",
                    "match": "(@)([\\p{L}_][\\p{L}\\p{N}_]*)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.annotation.valkyrie"
                        },
                        "2": {
                            "name": "entity.name.tag.decorator.valkyrie"
                        }
                    }
                },
                {
                    "name": "support.function.builtin.valkyrie",
                    "match": "@\\.(inline|specialize|const_fn|const_eval|derive|cfg|test|benchmark|deprecated|must_use|allow|warn|deny|forbid)"
                },
                {
                    "name": "entity.name.function.annotation.valkyrie",
                    "match": "@\\.[\\p{L}_][\\p{L}\\p{N}_]*"
                }
            ]
        },
        "function-definitions": {
            "patterns": [
                {
                    "name": "meta.function.definition.valkyrie",
                    "begin": "\\b(micro|mezzo|macro|method|get|set)\\s+([\\p{L}_][\\p{L}\\p{N}_]*)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.declaration.valkyrie"
                        },
                        "2": {
                            "name": "entity.name.function.valkyrie"
                        }
                    },
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#function-parameters"
                        }
                    ]
                },
                {
                    "name": "meta.constructor.definition.valkyrie",
                    "begin": "\\b(constructor)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.declaration.valkyrie"
                        }
                    },
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#function-parameters"
                        }
                    ]
                }
            ]
        },
        "function-parameters": {
            "patterns": [
                {
                    "name": "variable.parameter.valkyrie",
                    "match": "([\\p{L}_][\\p{L}\\p{N}_]*)\\s*(:)",
                    "captures": {
                        "1": {
                            "name": "variable.parameter.valkyrie"
                        },
                        "2": {
                            "name": "punctuation.separator.valkyrie"
                        }
                    }
                },
                {
                    "include": "#types"
                },
                {
                    "name": "punctuation.separator.valkyrie",
                    "match": ","
                }
            ]
        },
        "function-calls": {
            "patterns": [
                {
                    "name": "meta.function-call.valkyrie",
                    "begin": "\\b([\\p{L}_][\\p{L}\\p{N}_]*)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.function.call.valkyrie"
                        }
                    },
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#expressions"
                        }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.range.valkyrie",
                    "match": "\\.\\.=|\\.<|\\.\\.<"
                },
                {
                    "name": "keyword.operator.destructuring.valkyrie",
                    "match": "\\.\\.\\.(?=\\w)"
                },
                {
                    "name": "keyword.operator.arithmetic.valkyrie",
                    "match": "[×÷±∓∑∏√∛∜]"
                },
                {
                    "name": "keyword.operator.logical.valkyrie",
                    "match": "[∧∨¬⊕⊻⊼⊽]"
                },
                {
                    "name": "keyword.operator.comparison.valkyrie",
                    "match": "[≤≥≠≈≡≢]"
                },
                {
                    "name": "keyword.operator.arrow.valkyrie",
                    "match": "[→←↔⇒⇐⇔]"
                },
                {
                    "name": "keyword.operator.other.valkyrie",
                    "match": "[∘∘∘]"
                },
                {
                    "name": "keyword.operator.valkyrie",
                    "match": "(->|=>|::|:|==|!=|<=|>=|<|>|\\+|\\-|\\*|/|%|&&|\\|\\||!|=|\\|>|<\\||\\^|×)"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.valkyrie",
                    "match": ";"
                },
                {
                    "name": "punctuation.section.braces.valkyrie",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.section.brackets.valkyrie",
                    "match": "[\\[\\]]"
                },
                {
                    "name": "punctuation.section.parens.valkyrie",
                    "match": "[()]"
                },
                {
                    "name": "punctuation.separator.valkyrie",
                    "match": ","
                },
                {
                    "name": "punctuation.accessor.valkyrie",
                    "match": "\\."
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.valkyrie",
                    "match": "\\b[\\p{Ll}_][\\p{L}\\p{N}_]*\\b"
                }
            ]
        },
        "expressions": {
            "patterns": [
                {
                    "include": "#comments"
                },
                {
                    "include": "#keywords"
                },
                {
                    "include": "#strings"
                },
                {
                    "include": "#numbers"
                },
                {
                    "include": "#types"
                },
                {
                    "include": "#operators"
                },
                {
                    "include": "#identifiers"
                },
                {
                    "include": "#punctuation"
                }
            ]
        }
    }
}
